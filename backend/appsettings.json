{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=AppointmentDb;User=root;Password=root;"
  },
  "Jwt": {
    "Key": "your-super-secret-key-change-this",
    "Issuer": "AppointmentApi",
    "Audience": "AppointmentApiClient",
    "ExpiresInMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AppSettings": {
    "DefaultCurrency": "USD",
    "FrontendUrl": "http://localhost:3000"
  },
  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "EnableSsl": "true",
    "FromEmail": "your-email@gmail.com"
  },
  "Mailgun": {
    "BaseUrl": "https://api.mailgun.net/v3/",
    "Domain": "your-mailgun-domain",
    "ApiKey": "your-mailgun-api-key",
    "FromEmail": "your-mailgun-sender-email"
  },
  "GoogleCalendar": {
    "ClientId": "your-google-client-id",
    "ClientSecret": "your-google-client-secret",
    "RedirectUri": "https://your-domain.com/api/google-calendar/callback",
    "WebhookBaseUrl": "https://your-domain.com/api/google-calendar/webhook"
  },
  "AllowedHosts": "*"
}
